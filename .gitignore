# ════════════════════════════════════════════════
#  VNIT IG App — .gitignore
# ════════════════════════════════════════════════

# ─── Dependencies ────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm

# ─── Environment / Secrets ───────────────────────
# NEVER commit real secrets — use .env.example as template
.env
.env.local
.env.*.local
.env.production
.env.development
server/.env
client/.env.local
client/.env.production
RAILWAY_VARIABLES.env

# ─── Build outputs ───────────────────────────────
dist/
build/
.next/
out/

# ─── IDE / Editor ────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ─── OS files ────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Logs ────────────────────────────────────────
logs/
*.log
/tmp/

# ─── Uploads (user content) ─────────────────────
# Images are committed for deployment — council photos, dept logos, etc.
# Only exclude large temp files if needed.

# ─── Cache ───────────────────────────────────────
.eslintcache
.cache/

# ─── Backup / Debug files ───────────────────────
*.backup
README-BACKUP.md

# ─── Test artifacts ──────────────────────────────
coverage/
.nyc_output/

# ─── Docker (local volumes) ─────────────────────
docker-data/

# ─── Misc generated docs (kept locally) ─────────
PROJECT_DETAILED_FILE_TREE.txt
PROJECT_QUICK_SUMMARY.txt
