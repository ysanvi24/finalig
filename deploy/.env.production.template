# ══════════════════════════════════════════════════════════════
#  VNIT IG App — PRODUCTION Environment Variables (AWS EC2)
#  ──────────────────────────────────────────────────────────
#  Copy this file → server/.env on the AWS EC2 instance
#  Command: cp deploy/.env.production.template server/.env
#  Then fill in real values below.
# ══════════════════════════════════════════════════════════════

# ─── App ─────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# ─── Database ────────────────────────────────────────────────
# MongoDB Atlas connection string (Mumbai region recommended)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/vnit_sports?retryWrites=true&w=majority

# ─── JWT Authentication ─────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=CHANGE_ME_GENERATE_A_STRONG_SECRET

# ─── Google OAuth 2.0 ───────────────────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
# IMPORTANT: Add these to your OAuth client's authorized origins & redirect URIs:
#   Origin:   http://13.204.112.229
#   Redirect: http://13.204.112.229/api/auth/register-oauth
GOOGLE_CLIENT_ID=311672185118-fnu83et05guc71ffdf39r4meknj3lolj.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET_HERE
GOOGLE_CALLBACK_URL=http://13.204.112.229/api/auth/register-oauth

# ─── CORS ────────────────────────────────────────────────────
# Allow frontend on same server (Nginx serves on port 80)
CORS_ORIGIN=http://13.204.112.229

# ─── Base URL ────────────────────────────────────────────────
BASE_URL=http://13.204.112.229
